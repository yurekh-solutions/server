# MongoDB Atlas Connection
# Get your connection string from MongoDB Atlas Dashboard
# Format: mongodb+srv://<username>:<password>@cluster.mongodb.net/<database>?options
MONGODB_URI=mongodb+srv://<username>:<password>@urbanav.ltlh8va.mongodb.net/urbanav?retryWrites=true&w=majority&appName=urbanav

# Server Configuration
PORT=3002
NODE_ENV=development

# JWT Authentication
# Generate a strong secret key for production
JWT_SECRET=your_super_secret_jwt_key_change_in_production

# Stripe Payment Configuration
# Get these from Stripe Dashboard: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Email Configuration (Nodemailer)
# For Gmail: Enable 2FA and use App Password
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-email-app-password

# Client Application URL
CLIENT_URL=http://localhost:8081

# Cloudinary (image/file storage)
# Sign up at https://cloudinary.com/console and copy Cloud Name / API Key / Secret.
# If left blank, the server falls back to local /uploads disk storage (dev only).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Admin Panel Access
# Static token used by the Next.js admin dashboard (development). In production, prefer an admin JWT.
ADMIN_API_TOKEN=change-me-admin-dev-token

# Demo Login Credentials (admin testing only — not shown in apps)
DEMO_BUYER_EMAIL=buyer@test.com
DEMO_BUYER_PASSWORD=password123
DEMO_SUPPLIER_EMAIL=supplier@test.com
DEMO_SUPPLIER_PASSWORD=password123

# Notes:
# 1. Never commit .env file to version control
# 2. Add .env to .gitignore
# 3. For production, use environment variables from your hosting provider
# 4. MongoDB password should be URL-encoded (e.g., @ becomes %40)
