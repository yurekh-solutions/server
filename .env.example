# MongoDB Atlas Connection
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/urbanav?retryWrites=true&w=majority

# Server Configuration
PORT=4000
NODE_ENV=development

# JWT Authentication
JWT_SECRET=your_jwt_secret_here

# Razorpay Payment Configuration (primary gateway)
# Get keys from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret
PLATFORM_COMMISSION_PERCENT=5

# Email Configuration (Nodemailer)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-email-password

# Client Application URL
CLIENT_URL=http://localhost:8081

# Admin Panel Access
ADMIN_API_TOKEN=your-admin-token

# Google OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID_WEB=your_web_client_id
GOOGLE_CLIENT_ID_ANDROID=your_android_client_id
GOOGLE_CLIENT_ID_IOS=your_ios_client_id
GOOGLE_CLIENT_ID_EXPO=your_expo_client_id

# Cloudinary Configuration (image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
